{
  "name": "status-code-checker",
  "version": "1.0.0",
  "type": "module",
  "description": "Takes a url string or array of url strings and returns the status code of those urls",
  "preferGlobal": true,
  "bin": {
    "status-check": "./bin/status-check.mjs"
  },
  "keywords": [
    "http",
    "status",
    "checker",
    "url",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 vitest"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/okize/status-code-checker.git"
  },
  "bugs": "https://github.com/okize/status-code-checker/issues",
  "homepage": "https://github.com/okize/status-code-checker/",
  "author": {
    "name": "Morgan Wigmanich",
    "email": "okize123@gmail.com",
    "url": "https://github.com/okize"
  },
  "license": "MIT"
}
